{
  "headers": [
    {
      "source": "/(.*\\.b3dm)",
      "headers": [
        { "key": "Content-Type", "value": "application/octet-stream" }
      ]
    },
    {
      "source": "/(.*\\.i3dm)",
      "headers": [
        { "key": "Content-Type", "value": "application/octet-stream" }
      ]
    },
    {
      "source": "/(.*\\.pnts)",
      "headers": [
        { "key": "Content-Type", "value": "application/octet-stream" }
      ]
    },
    {
      "source": "/(.*\\.cmpt)",
      "headers": [
        { "key": "Content-Type", "value": "application/octet-stream" }
      ]
    },
    {
      "source": "/(.*\\.glb)",
      "headers": [
        { "key": "Content-Type", "value": "model/gltf-binary" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|cesium/|CesiumAir/|GeoJson/|Tileset/).*)",
      "destination": "/index.html"
    }
  ]
}
